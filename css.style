body {
    width: 100vw;
    height: 100vh;
    margin: 0;
    padding: 0;
}

.tools {
    height: 100%;
    display: inherit;
    flex-direction: column;
    margin: 0;
    font-size: 1.1em;
}

div {
    margin: .25em;
    text-align: center;
}

input {
    outline: none;
    cursor: pointer;
}

input[type="color"] {
    width: 30px;
    height: 30px;
}

input[type="button"] {
    width: 80%;
    padding: .5em;
    margin-bottom: .5em;
    font-size: .8em;
}
